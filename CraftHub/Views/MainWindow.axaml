<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:CraftHub.ViewModels"
		xmlns:views="using:CraftHub.Views"
		xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
		x:Class="CraftHub.Views.MainWindow"
		Title="CraftHub"
		MinWidth="1100" MinHeight="600"
		Width="1200" Height="750"
		WindowStartupLocation="CenterScreen"
		Background="{DynamicResource AppBackground}"
		Closing="Window_Closing">

	<Grid RowDefinitions="Auto,*,Auto">

		<!-- Title bar area -->
		<Border Grid.Row="0" Background="{DynamicResource ElevatedBackground}" Padding="16,10">
			<Grid ColumnDefinitions="Auto,*">
				<Grid Grid.Column="0"
					  ColumnDefinitions="Auto,*">
					<TextBlock Text="CraftHub" FontSize="18" FontWeight="Bold"
							   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
					<TextBlock Text="{Binding CurrentVersion}"
							   FontSize="11"
							   Grid.Column="1"
							   FontWeight="Bold"
							   Foreground="{DynamicResource AccentPrimary}"/>
				</Grid>
				<StackPanel Orientation="Horizontal" Spacing="10" Grid.Column="1" HorizontalAlignment="Right">
					<Button Content="{materialIcons:MaterialIconExt Kind=Update}"
							Foreground="{DynamicResource WarningColor}"
							IsVisible="{Binding ShowUpdateButton}"
							Classes="toolbar-btn"
							Command="{Binding DownloadAndStartUpdateCommand}"
							ToolTip.Tip="{DynamicResource UpdateTip}" FontSize="16" />
					<Button Content="{materialIcons:MaterialIconExt Kind=Github}" Classes="toolbar-btn"
							Command="{Binding GoToGitHubRepoCommand}"
							ToolTip.Tip="{DynamicResource GitHub}" FontSize="16" />
					<Button Content="{materialIcons:MaterialIconExt Kind=BellNotificationOutline}" Classes="toolbar-btn"
					        Command="{Binding ToggleNotificationManagerCommand}"
					        ToolTip.Tip="{DynamicResource NotificationsTip}" FontSize="16" />
					<Button Classes="toolbar-btn"
							Command="{Binding ToggleThemeCommand}"
							Content="{materialIcons:MaterialIconExt Kind=ThemeLightDark}"
							ToolTip.Tip="{DynamicResource ToggleThemeTip}" FontSize="16" />
					<Button Classes="toolbar-btn"
							Command="{Binding ToggleLanguageCommand}"
							ToolTip.Tip="{DynamicResource ToggleLanguageTip}"
							Content="{Binding CurrentLang}"
							FontSize="13" FontWeight="SemiBold"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Main content: file explorer + current workspace -->
		<Grid Grid.Row="1" x:Name="MainContentGrid">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="0" MinWidth="0"/>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<!-- File explorer panel -->
			<views:FileExplorerView Grid.Column="0"
									DataContext="{Binding FileExplorer}"
									IsVisible="{Binding IsVisible}"/>

			<GridSplitter Grid.Column="1"
						  Width="5"
						  Background="Transparent"
						  ResizeDirection="Columns"
						  ResizeBehavior="PreviousAndNext"
						  IsVisible="{Binding FileExplorer.IsVisible}" />

			<!-- Workspace content -->
			<Border Grid.Column="2" Background="{DynamicResource SurfaceBackground}" Margin="0">
				<Panel>
					<ItemsControl ItemsSource="{Binding Workspaces}"
								  IsVisible="{Binding HasWorkspaces}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<Panel />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
								<views:WorkspaceView IsVisible="{Binding IsActive}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<!-- Empty state: no workspace tabs open -->
					<StackPanel IsVisible="{Binding !HasWorkspaces}"
								VerticalAlignment="Center"
								HorizontalAlignment="Center"
								Spacing="16"
								Margin="24">
						<materialIcons:MaterialIcon Kind="TableLarge"
													Width="52" Height="52"
													HorizontalAlignment="Center"
													Foreground="{DynamicResource TextMuted}" />
						<TextBlock Text="{DynamicResource NoWorkspaceMsg}"
								   FontSize="14"
								   TextAlignment="Center"
								   TextWrapping="Wrap"
								   MaxWidth="360"
								   Foreground="{DynamicResource TextMuted}" />
						<Button Classes="accent-btn"
								Padding="16,8"
								HorizontalAlignment="Center"
								Command="{Binding AddWorkspaceCommand}"
								Content="{DynamicResource NewWorkspaceBtn}" />
					</StackPanel>
				</Panel>
			</Border>
		</Grid>

		<!-- Bottom tab bar -->
		<Border Grid.Row="2" Background="{DynamicResource ElevatedBackground}" Padding="8,8"
				BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
			<Grid ColumnDefinitions="*,Auto">
				<ScrollViewer Grid.Column="0"
							  HorizontalScrollBarVisibility="Auto"
							  VerticalScrollBarVisibility="Disabled"
							  VerticalAlignment="Center">
					<ItemsControl ItemsSource="{Binding Workspaces}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="0" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate DataType="{x:Type vm:WorkspaceViewModel}">
								<Button Classes="tab-shell"
										Classes.tab-active="{Binding IsActive}"
										Command="{Binding $parent[Window].DataContext.SelectWorkspaceCommand}"
										CommandParameter="{Binding}"
										ToolTip.Tip="{Binding FilePath}">
									<Button.ContextMenu>
										<ContextMenu>
											<MenuItem Header="{DynamicResource RenameTab}"
													  Command="{Binding RenameCommand}" />
											<MenuItem Header="{DynamicResource CloseTab}"
													  Command="{Binding CloseCommand}" />
										</ContextMenu>
									</Button.ContextMenu>
									<Grid ColumnDefinitions="Auto,*,Auto">
										<Ellipse Grid.Column="0"
												 Width="8" Height="8"
												 Margin="2,0,0,0"
												 VerticalAlignment="Center"
												 Fill="{DynamicResource WarningColor}"
												 IsVisible="{Binding IsModified}"
												 ToolTip.Tip="{DynamicResource UnsavedTip}" />
										<TextBlock Grid.Column="1"
												   Text="{Binding Header}"
												   VerticalAlignment="Center"
												   Margin="6,0,0,0" />
										<Button Classes="tab-close"
												Grid.Column="2"
												Content="{materialIcons:MaterialIconExt Kind=CloseThick}"
												Margin="6,0,0,0"
												Command="{Binding CloseCommand}" />
									</Grid>
								</Button>

							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>

				<Button Grid.Column="1"
						Classes="tab-add"
						VerticalAlignment="Center" Margin="10,0,0,0"
						Content="{materialIcons:MaterialIconExt Kind=PlusThick}"
						Command="{Binding AddWorkspaceCommand}"
						ToolTip.Tip="{DynamicResource AddWorkspaceTip}" />
			</Grid>
		</Border>

		<!-- Notification overlays -->
		<StackPanel Grid.RowSpan="3"
					Margin="20,20,20,30"
					HorizontalAlignment="Right"
					VerticalAlignment="Bottom"
					Spacing="8"
					IsVisible="{Binding ShowPopupOverlay}">
			<ItemsControl ItemsSource="{Binding ActiveNotifications}"
						  ItemTemplate="{StaticResource NotificationTemplate}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Vertical" Spacing="8" />
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>
			</ItemsControl>
		</StackPanel>

		<Border Grid.RowSpan="3"
				HorizontalAlignment="Right"
				VerticalAlignment="Bottom"
				Margin="20,20,20,30"
				Width="320"
				Padding="16"
				CornerRadius="16"
				Background="{DynamicResource SurfaceBackground}"
				BorderBrush="{DynamicResource BorderColor}"
				BorderThickness="1"
				IsVisible="{Binding IsNotificationManagerOpen}">
			<StackPanel Spacing="12">
				<Grid ColumnDefinitions="*,Auto">
					<TextBlock Text="{DynamicResource NotificationsTitle}" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextPrimary}" />
					<Button Content="{materialIcons:MaterialIconExt Kind=CloseThick}" Classes="close-tab"
							Grid.Column="1"
							Command="{Binding ToggleNotificationManagerCommand}"
							Margin="0" />
				</Grid>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
					<ToggleSwitch IsChecked="{Binding ShowNotificationPopups}"
								  OffContent="{DynamicResource PopupsOff}"
								  OnContent="{DynamicResource PopupsOn}" />
					<Button Content="{DynamicResource ClearAll}" Classes="tab-btn"
							Command="{Binding ClearNotificationHistoryCommand}"
							FontSize="12"
							Padding="10,4" />
				</StackPanel>
				<ScrollViewer x:Name="NotificationHistoryScroll"
							  MaxHeight="260"
							  VerticalScrollBarVisibility="Visible"
							  HorizontalScrollBarVisibility="Disabled">
					<Grid RowDefinitions="Auto,*">
						<TextBlock Grid.Row="0"
								   Text="{DynamicResource NoNotificationsYet}"
								   Foreground="{DynamicResource TextMuted}"
								   FontSize="12"
								   HorizontalAlignment="Center"
								   Margin="0,10">
							<TextBlock.IsVisible>
								<Binding Path="Notifications.Count"
										 Converter="{StaticResource CountToVisibility}"
										 ConverterParameter="empty" />
							</TextBlock.IsVisible>
						</TextBlock>

						<ItemsControl Grid.Row="1"
									  ItemsSource="{Binding Notifications}"
									  ItemTemplate="{StaticResource NotificationRowTemplate}">
							<ItemsControl.IsVisible>
								<Binding Path="Notifications.Count"
										 Converter="{StaticResource CountToVisibility}"
										 ConverterParameter="notEmpty" />
							</ItemsControl.IsVisible>
						</ItemsControl>
					</Grid>
				</ScrollViewer>
			</StackPanel>
		</Border>
	</Grid>
</Window>
